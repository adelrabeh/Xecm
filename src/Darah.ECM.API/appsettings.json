{
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "darah.ecm.api",
    "Audience": "darah.ecm.client",
    "ExpiryMinutes": 15,
    "RefreshExpiryHours": 8
  },
  "Storage": {
    "Provider": "LocalFileSystem",
    "LocalPath": "C:\\ecm-storage",
    "MaxFileSizeBytes": 536870912
  },
  "Hangfire": {
    "WorkerCount": 4
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Darah.ECM": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "C:\\ecm-logs\\ecm-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}
